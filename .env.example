# Application
NODE_ENV=production
PORT=3000

# RapidAPI
RAPID_API_KEY=your_rapidapi_key_here
RAPID_API_HOST=tradingview-data1.p.rapidapi.com

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Fetch scheduler
FETCH_INTERVAL=300000

# Cache TTL in seconds
CACHE_TTL=60

# CORS
ALLOWED_ORIGINS=https://yourwordpresssite.com,http://localhost:8080

# Logging
LOG_LEVEL=info
